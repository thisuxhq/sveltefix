{
  "name": "@thisux/sveltefix-mcp",
  "version": "0.1.1",
  "description": "MCP server for sveltefix — connects AI agents to visual browser annotations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sveltefix-mcp": "./dist/bin/cli.js",
    "@thisux/sveltefix-mcp": "./dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/cli.js server",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "hono": "^4.7.0",
    "nanoid": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["svelte", "mcp", "claude", "ai", "annotations", "developer-tools"],
  "license": "MIT"
}
